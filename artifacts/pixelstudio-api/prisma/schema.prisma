// schema.prisma — Prisma Database Schema
//
// This file defines all the tables (models) in your MySQL database.
// Run "npm run db:migrate" to apply changes to the actual database.
// Run "npm run db:generate" to regenerate the Prisma Client after changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Admin ────────────────────────────────────────────────────────────────────
// Only one admin account exists in the system
model Admin {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  password  String   // hashed with bcrypt
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Staff ────────────────────────────────────────────────────────────────────
// Photographers / team members managed by the admin
model Staff {
  id        String        @id @default(uuid())
  name      String
  email     String        @unique
  phone     String
  username  String        @unique
  password  String        // hashed with bcrypt
  status    StaffStatus   @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // A staff member can have many clients
  clients   Client[]
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

// ─── Client ───────────────────────────────────────────────────────────────────
// A client record created by staff for a photography session
model Client {
  id            String        @id @default(uuid())
  clientName    String
  phone         String
  price         Decimal       @db.Decimal(12, 2)
  photoFormat   PhotoFormat   @default(SOFTCOPY)
  paymentStatus PaymentStatus @default(PENDING)
  orderStatus   OrderStatus   @default(PENDING)
  notes         String?       @db.Text
  invoiceId     String        @unique
  galleryToken  String        @unique  // used to generate the public gallery link
  shootDate     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Which staff member created this client
  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  // A client can have many uploaded photos
  photos  Photo[]

  // One invoice per client
  invoice Invoice?
}

enum PhotoFormat {
  SOFTCOPY
  HARDCOPY
  BOTH
}

enum PaymentStatus {
  PAID
  PENDING
}

enum OrderStatus {
  PENDING
  EDITING
  READY
  DELIVERED
}

// ─── Photo ────────────────────────────────────────────────────────────────────
// Individual photos uploaded for a client
model Photo {
  id         String   @id @default(uuid())
  filename   String   // the file stored on disk (e.g. "photo-1234567890.jpg")
  url        String   // the publicly accessible URL (e.g. "/uploads/photo-1234567890.jpg")
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedAt DateTime @default(now())
}

// ─── Invoice ──────────────────────────────────────────────────────────────────
// Invoice generated per client session
model Invoice {
  id          String        @id @default(uuid())
  invoiceNo   String        @unique  // e.g. "INV-0001"
  amount      Decimal       @db.Decimal(12, 2)
  status      PaymentStatus @default(PENDING)
  issuedAt    DateTime      @default(now())
  paidAt      DateTime?

  clientId    String        @unique
  client      Client        @relation(fields: [clientId], references: [id])
}
