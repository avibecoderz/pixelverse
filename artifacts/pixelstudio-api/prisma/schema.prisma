// schema.prisma — Prisma Database Schema
//
// This file defines all the tables (models) in your MySQL database.
// Run "npm run db:migrate" to apply changes to the actual database.
// Run "npm run db:generate" to regenerate the Prisma Client after changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Admin ────────────────────────────────────────────────────────────────────
// Only one admin account exists in the system.
model Admin {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  password  String   // hashed with bcrypt — NEVER store plain text
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Staff ────────────────────────────────────────────────────────────────────
// Photographers / team members managed by the admin.
model Staff {
  id        String      @id @default(uuid())
  name      String
  email     String      @unique
  phone     String
  username  String      @unique
  password  String      // hashed with bcrypt
  status    StaffStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // A staff member can have many clients
  clients Client[]
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

// ─── Client ───────────────────────────────────────────────────────────────────
// A client record created by a staff member for a photography session.
model Client {
  id            String        @id @default(uuid())
  clientName    String
  phone         String
  price         Decimal       @db.Decimal(12, 2)
  photoFormat   PhotoFormat   @default(SOFTCOPY)
  paymentStatus PaymentStatus @default(PENDING)
  orderStatus   OrderStatus   @default(PENDING)
  notes         String?       @db.Text
  invoiceId     String        @unique   // business-facing number e.g. "INV-0001"
  galleryToken  String        @unique   // random token for the public gallery share link
  shootDate     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Which staff member owns this client record.
  // FIX: onDelete: Restrict prevents deleting a staff member who still has clients.
  // The admin must reassign or delete the clients first.
  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Restrict)

  // A client can have many uploaded photos (deleted automatically when client is deleted)
  photos Photo[]

  // One invoice per client (optional until generated)
  invoice Invoice?
}

enum PhotoFormat {
  SOFTCOPY
  HARDCOPY
  BOTH
}

enum PaymentStatus {
  PAID
  PENDING
}

enum OrderStatus {
  PENDING
  EDITING
  READY
  DELIVERED
}

// ─── Photo ────────────────────────────────────────────────────────────────────
// Individual photo files uploaded for a client session.
model Photo {
  id         String   @id @default(uuid())
  filename   String   // filename on disk, e.g. "photo-1712345678901-portrait.jpg"
  url        String   // publicly accessible URL, e.g. "/uploads/photo-....jpg"
  clientId   String
  // onDelete: Cascade — deleting a client also deletes all their photos in DB
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

// ─── Invoice ──────────────────────────────────────────────────────────────────
// One invoice per client, generated by staff after the session.
model Invoice {
  id        String        @id @default(uuid())
  invoiceNo String        @unique   // e.g. "INV-0001" (mirrors client.invoiceId)
  amount    Decimal       @db.Decimal(12, 2)
  status    PaymentStatus @default(PENDING)
  issuedAt  DateTime      @default(now())
  paidAt    DateTime?     // set when payment is recorded

  // One-to-one with Client
  clientId String  @unique
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}
