generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                @id @default(uuid())
  name              String
  email             String                @unique
  phone             String
  password          String
  role              Role                  @default(STAFF)
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  clientsCreated    Client[]              @relation("ClientCreatedBy")
  galleriesUploaded Gallery[]             @relation("GalleryUploadedBy")
  invoicesCreated   Invoice[]             @relation("InvoiceCreatedBy")
  passwordReset     PasswordResetSession?
  paymentsReceived  Payment[]             @relation("PaymentReceivedBy")

  @@map("users")
}

model PasswordResetSession {
  id                  String    @id @default(uuid())
  otpHash             String
  otpExpiresAt        DateTime
  attemptCount        Int       @default(0)
  lastSentAt          DateTime  @default(now())
  verifiedAt          DateTime?
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_sessions")
}

model Client {
  id            String        @id @default(uuid())
  clientName    String
  phone         String
  price         Decimal       @db.Decimal(12, 2)
  photoFormat   PhotoFormat   @default(SOFTCOPY)
  paymentStatus PaymentStatus @default(PENDING)
  orderStatus   OrderStatus   @default(PENDING)
  notes         String?
  galleryToken  String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdById   String
  createdBy     User          @relation("ClientCreatedBy", fields: [createdById], references: [id])
  gallery       Gallery?
  invoices      Invoice[]
  payments      Payment[]
  photos        Photo[]

  @@map("clients")
}

model Gallery {
  id           String   @id @default(uuid())
  token        String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clientId     String   @unique
  uploadedById String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("GalleryUploadedBy", fields: [uploadedById], references: [id])
  photos       Photo[]

  @@map("galleries")
}

model Photo {
  id        String   @id @default(uuid())
  imageUrl  String
  publicId  String?
  fileName  String
  createdAt DateTime @default(now())
  clientId  String
  galleryId String
  client    Client   @relation(fields: [clientId], references: [id])
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  amount        Decimal       @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  clientId      String
  createdById   String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  @@map("invoices")
}

model Payment {
  id           String        @id @default(uuid())
  amount       Decimal       @db.Decimal(12, 2)
  status       PaymentStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  clientId     String
  receivedById String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  receivedBy   User          @relation("PaymentReceivedBy", fields: [receivedById], references: [id])

  @@map("payments")
}

enum Role {
  ADMIN
  STAFF
}

enum PhotoFormat {
  SOFTCOPY
  HARDCOPY
  BOTH
}

enum PaymentStatus {
  PENDING
  PAID
}

enum OrderStatus {
  PENDING
  EDITING
  READY
  DELIVERED
}
