{
  "name": "pixelstudio-api",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "PixelStudio Photography Management System - REST API backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "pnpm exec prisma generate && pnpm exec prisma db push",
    "postinstall": "pnpm exec prisma generate",
    "db:generate": "pnpm exec prisma generate",
    "db:migrate": "pnpm exec prisma migrate dev --name init",
    "db:studio": "pnpm exec prisma studio",
    "db:push": "pnpm exec prisma db push",
    "db:seed": "node src/utils/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
