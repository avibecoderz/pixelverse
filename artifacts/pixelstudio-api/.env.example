PORT=3000
NODE_ENV=development

# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"
# Use a long random secret in production
JWT_SECRET="change_this_to_a_very_long_secret_key"
JWT_EXPIRES_IN="7d"

# Studio settings
STUDIO_NAME="PixelStudio"
STUDIO_ADDRESS="14 Admiralty Way, Lekki Phase 1, Lagos, Nigeria"

# Leave empty in local development unless you need to restrict CORS
FRONTEND_URL="https://your-frontend-domain.com"

# Optional SMTP settings for real password reset emails.
# When omitted locally, the OTP is logged to the server console instead.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
SMTP_FROM="PixelStudio <no-reply@yourdomain.com>"

# Max file size in bytes (20 MB default)
MAX_FILE_SIZE=20971520
UPLOAD_DIR="uploads"
