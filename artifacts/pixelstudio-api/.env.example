# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MySQL Database ───────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:yourpassword@localhost:3306/pixelstudio"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long, random secret in production (e.g. openssl rand -hex 64)
JWT_SECRET="change_this_to_a_very_long_secret_key"
JWT_EXPIRES_IN="7d"

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Max file size in bytes (default: 20MB)
MAX_FILE_SIZE=20971520
UPLOAD_DIR="uploads"

# ─── Frontend ─────────────────────────────────────────────────────────────────
# The URL where your PixelStudio frontend is running (for CORS)
FRONTEND_URL="http://localhost:5173"
