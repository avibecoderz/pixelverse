# PixelStudio Frontend — Local Environment Variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is loaded automatically by Vite during development.
# It is ignored by git — never commit your real values.
#
# The URL of your running PixelStudio backend.
# Change the port to match wherever your backend is running.
VITE_API_URL=http://localhost:4000
