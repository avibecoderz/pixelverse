# ─── PixelStudio Frontend — Development Environment ──────────────────────────
#
# Leave VITE_API_URL empty so the Vite dev server proxy handles API requests.
# Requests to /api/* and /uploads/* are forwarded to the backend at port 3000.
# This avoids CORS issues and works seamlessly in the Replit environment.
VITE_API_URL=
